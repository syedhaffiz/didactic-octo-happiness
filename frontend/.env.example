# Copy to `.env.local` and fill in. Vite picks up `.env.local` automatically.

# --- API ---------------------------------------------------------------
# Where the backend lives. Defaults to localhost:4000 if unset.
VITE_API_BASE_URL=http://localhost:4000/api

# --- Data source -------------------------------------------------------
# `true` → frontend serves Inventory data from mocks (see src/mocks/).
# `false` → frontend hits the backend.
VITE_USE_MOCK_DATA=true

# --- SSO toggle --------------------------------------------------------
# `true` (or unset) → Azure SSO is required (the vars below must be filled in)
#   and the app is gated behind a Microsoft sign-in.
# `false` → SSO is skipped: APIs receive a dummy bearer token and the header
#   shows a placeholder user. Works in local dev AND deployed builds (it's read
#   at build time, so set it in the pipeline/host env).
VITE_SSO_ENABLED=true

# --- Azure AD / Entra ID SSO (required only when VITE_SSO_ENABLED=true) -
# Create an app registration in the Azure portal under Microsoft Entra ID →
# App registrations → New, set the platform to "Single-page application" with
# redirect URI matching VITE_AZURE_REDIRECT_URI below, then copy the IDs from
# the Overview page.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
# Defaults to window.location.origin if unset. Must exactly match a redirect
# URI registered under the SPA platform in Azure.
VITE_AZURE_REDIRECT_URI=
