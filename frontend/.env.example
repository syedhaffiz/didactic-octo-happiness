# Copy to `.env.local` and fill in. Vite picks up `.env.local` automatically.

# --- API ---------------------------------------------------------------
# Where the backend lives. Defaults to localhost:4000 if unset.
VITE_API_BASE_URL=http://localhost:4000/api

# --- Data source -------------------------------------------------------
# `true` → frontend serves Inventory data from mocks (see src/mocks/).
# `false` → frontend hits the backend.
VITE_USE_MOCK_DATA=true

# --- Auth (silent SSO) -------------------------------------------------
# The remote signs in SILENTLY with its own app registration, riding the
# session the host already established for the same user/tenant (ssoSilent,
# prompt=none). No interactive prompt and no sign-out live here — those are
# the host's job. Leave VITE_AZURE_CLIENT_ID blank to run token-less.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
# Optional: SPA redirect URI for the silent iframe; defaults to the current
# origin (the HOST's origin when federated). Must be registered in Azure under
# the remote's app registration as an SPA redirect URI.
VITE_AZURE_REDIRECT_URI=
