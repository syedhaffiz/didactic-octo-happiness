# Copy to `.env.local` and fill in.

# Azure AD app registration (REQUIRED). The host owns sign-in; the remote
# inherits the session via shared MSAL singleton.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
# Must be a registered redirect URI in the Azure SPA platform config.
VITE_AZURE_REDIRECT_URI=http://localhost:3000

# Override the remote's entry URL (defaults to localhost:5173).
# VITE_CONTROL_TOWER_REMOTE=https://control-tower.example.com/remoteEntry.js
