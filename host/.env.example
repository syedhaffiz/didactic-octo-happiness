# Copy to `.env.local` and fill in. The host owns SSO for the whole portal;
# the remote consumes the host's token.

# --- Azure AD / Entra ID SSO (required) --------------------------------
# Create an app registration in the Azure portal (Microsoft Entra ID →
# App registrations), platform "Single-page application". The redirect URI
# must be the host origin and registered under the SPA platform in Azure.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
VITE_AZURE_REDIRECT_URI=http://localhost:3000
