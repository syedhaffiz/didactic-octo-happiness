# Copy to `.env.local` and fill in. The host owns SSO for the whole portal.

# --- SSO toggle --------------------------------------------------------
# `true` (or unset) → host requires Azure SSO (vars below) and the remote
#   reuses the session. `false` → no SSO: placeholder user, and the remote is
#   told to run without SSO too. Lets you demo federation without Azure.
VITE_SSO_ENABLED=true

# --- Azure AD / Entra ID SSO (required only when VITE_SSO_ENABLED=true) -
# Same app-registration pattern as the remote. The host signs the user in;
# the remote reuses this session. Redirect URI must be the host origin
# (http://localhost:3000) and registered under the SPA platform in Azure.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
VITE_AZURE_REDIRECT_URI=http://localhost:3000
